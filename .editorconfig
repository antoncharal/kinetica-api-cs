root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{json,yml,yaml,md,props,targets,csproj,slnx}]
indent_size = 2

[*.cs]
# .NET formatting
dotnet_sort_system_directives_first = true
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion

# C# formatting
csharp_new_line_before_open_brace = all
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_style_namespace_declarations = file_scoped:suggestion
csharp_prefer_braces = true:suggestion

# Naming (minimal; stricter rules can land later)
dotnet_naming_rule.interface_should_be_prefixed_with_i.severity = suggestion
dotnet_naming_rule.interface_should_be_prefixed_with_i.symbols = interface
dotnet_naming_rule.interface_should_be_prefixed_with_i.style = begins_with_i

dotnet_naming_symbols.interface.applicable_kinds = interface
dotnet_naming_symbols.interface.applicable_accessibilities = public, internal, private, protected, protected_internal, private_protected

dotnet_naming_style.begins_with_i.required_prefix = I
dotnet_naming_style.begins_with_i.capitalization = pascal_case

# Analyzer severities (explicit known-noise silencing)
dotnet_diagnostic.CA1305.severity = none
dotnet_diagnostic.CA1307.severity = none
dotnet_diagnostic.CA2007.severity = none

# PR-10: Async discipline — ship as errors in library.
# VSTHRD002: Avoid .Result / .Wait — deadlock risk.
dotnet_diagnostic.VSTHRD002.severity = error
# VSTHRD110: Observe the result of async calls.
dotnet_diagnostic.VSTHRD110.severity = error
# VSTHRD111: Use .ConfigureAwait(bool) — every await site.
dotnet_diagnostic.VSTHRD111.severity = error
# VSTHRD200: "Async" suffix — naming convention, informational.
dotnet_diagnostic.VSTHRD200.severity = suggestion

# PR-10: Disposable hygiene.
# CA1816: Call GC.SuppressFinalize(this) in Dispose.
dotnet_diagnostic.CA1816.severity = error

# G1 (Section G): Protocol/ and ColumnProperty.cs are autogenerated files.
# CS1591 (missing XML doc) is intentionally not enforced here; documentation
# belongs in the schema processor, not in handwritten suppressions.
[Kinetica/Protocol/*.cs]
dotnet_diagnostic.CS1591.severity = none

[Kinetica/ColumnProperty.cs]
dotnet_diagnostic.CS1591.severity = none
